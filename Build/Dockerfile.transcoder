FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends ffmpeg && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir python-dotenv imageio-ffmpeg boto3

COPY . /app

ENTRYPOINT ["python", "server/transcoder.py"]
CMD ["sample-asset-id", "/app/uploads/input.mp4"]
